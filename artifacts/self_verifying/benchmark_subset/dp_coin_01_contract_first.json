  "solution_preview": "def solve(coins, amount):\n                dp = [float('inf')] * (amount + 1)\n                dp[0] = 0\n                for coin in coins:\n                    for value in range(coin, amount + 1):\n                        dp[value] = min(dp[value], dp[value - coin] + 1)\n                return dp[amount] if dp[amount] != float('inf') else -1"
