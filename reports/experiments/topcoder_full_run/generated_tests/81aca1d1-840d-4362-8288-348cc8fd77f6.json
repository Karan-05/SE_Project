[
  {
    "name": "test_register_event_handler",
    "mode": "call",
    "expected": "Handler registered successfully",
    "input": [
      {
        "topic": "avscan.action.scan",
        "handler": "AVScanActionScanHandler"
      }
    ]
  },
  {
    "name": "test_route_message_to_handler",
    "mode": "call",
    "expected": "Received event payload: {\"id\": 123, \"status\": \"completed\"}",
    "input": [
      {
        "topic": "avscan.action.scan",
        "payload": {
          "id": 123,
          "status": "completed"
        }
      }
    ]
  },
  {
    "name": "test_handler_logging",
    "mode": "call",
    "expected": "Log: Received event payload: {\"id\": 456, \"status\": \"failed\"}",
    "input": [
      {
        "topic": "avscan.action.scan",
        "payload": {
          "id": 456,
          "status": "failed"
        }
      }
    ]
  },
  {
    "name": "test_handler_error_handling",
    "mode": "call",
    "expected": "Error processing message: Invalid payload",
    "input": [
      {
        "topic": "avscan.action.scan",
        "payload": {
          "id": null,
          "status": "error"
        }
      }
    ]
  }
]