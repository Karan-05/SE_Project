        }
      }
    ]
  },
  {
    "name": "get_invites",
    "mode": "call",
    "expected": [
      {
        "id": "1",
        "email": "invitee@example.com",
        "status": "pending"
      }
    ],
    "input": [
      {
        "projectId": "123",
        "fields": "id,email,status"
      }
    ]
  },
  {
    "name": "accept_invite",
    "mode": "call",
    "expected": {
      "status": "accepted"
    },
    "input": [
      {
        "projectId": "123",
        "inviteId": "1"
      }
    ]
  },
  {
    "name": "delete_member",
    "mode": "call",
    "expected": {
      "status": "deleted"
    },
    "input": [
      {
        "projectId": "123",
        "memberId": "2"
      }
    ]
  },
  {
    "name": "duplicate_invite",
    "mode": "call",
